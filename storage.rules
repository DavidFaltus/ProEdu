rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function for user authentication status
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rule 12: Namespaced paths, authentication, content type whitelist, and file size limits
    match /learningSheets/{userId}/{fileId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
                    isOwner(userId) && 
                    request.resource.size < 15 * 1024 * 1024 &&
                    (request.resource.contentType == 'application/pdf' || request.resource.contentType.startsWith('image/'));
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
                    isOwner(userId) && 
                    request.resource.size < 5 * 1024 * 1024 && 
                    request.resource.contentType.startsWith('image/');
    }
    
    // Strict least privilege principle on unmanaged paths
    match /{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
