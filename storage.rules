rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Pomocné funkce pro bezpečnost v souladu s proedu.md
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rule 12: Namespaced path pro učební materiály
    match /learningSheets/{teacherUid}/{fileId} {
      // Číst mohou všichni přihlášení
      allow read: if isAuthenticated();
      
      // Zápis - obnovujeme základní ochranu (server-side proxy obchází tato pravidla)
      allow write: if isAuthenticated() && isOwner(teacherUid);
                   
      allow delete: if isAuthenticated() && isOwner(teacherUid);
    }

    // Obecná složka pro uživatelské assety (např. avatary)
    match /users/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(userId)
                   && request.resource.size < 1 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Složka pro odevzdání testů
    match /testSubmissions/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow write: if isAuthenticated() && isOwner(userId)
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
    }
    
    // Zákaz všeho ostatního (Rule 16: Least Privilege)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
