rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Pomocné funkce pro bezpečnost v souladu s proedu.md
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Zjednodušená pravidla pro nahrávání PDF a materiálů
    match /learningSheets/{userId}/{fileId} {
      allow read: if isAuthenticated();
      // Povoleno nahrávání pokud je to uloženo pod vlastním ID
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Pro jakékoli jiné složky ve storage
    match /{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
