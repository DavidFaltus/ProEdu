{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Test": {
      "title": "Test",
      "description": "Test template created by teacher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "string" }
            }
          }
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "questions", "createdBy"]
    },
    "AssignedTest": {
      "title": "AssignedTest",
      "description": "A test assigned to a specific student",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "testId": { "type": "string" },
        "studentId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "submitted", "graded"] },
        "answers": { "type": "object" },
        "grade": { "type": "string" },
        "feedback": { "type": "string" },
        "assignedAt": { "type": "string", "format": "date-time" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "gradedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["testId", "studentId", "status", "assignedAt"]
    },
    "LearningSheet": {
      "title": "LearningSheet",
      "description": "Educational material",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "createdBy"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/tests/{testId}": {
      "schema": "Test",
      "description": "Test templates"
    },
    "/assignedTests/{assignedTestId}": {
      "schema": "AssignedTest",
      "description": "Tests assigned to students"
    },
    "/learningSheets/{sheetId}": {
      "schema": "LearningSheet",
      "description": "Learning materials"
    }
  }
}
