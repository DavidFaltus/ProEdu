rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' ||
          request.auth.token.email == "davidfaltus03@gmail.com" ||
          request.auth.token.email == "ucitel@ucitel.cz"
        );
    }

    function unchanged(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    function keepsImmutableFields() {
      return unchanged('uid') &&
        unchanged('createdAt') &&
        unchanged('createdBy') &&
        unchanged('studentId') &&
        unchanged('testId');
    }

    match /users/{uid} {
      allow read: if isAuthenticated() && (isOwner(uid) || isAdmin());
      allow create: if isAuthenticated() &&
        isOwner(uid) &&
        request.resource.data.role == 'student';
      allow update: if isAuthenticated() &&
        (isOwner(uid) || isAdmin()) &&
        keepsImmutableFields() &&
        (isAdmin() || request.resource.data.role == resource.data.role);
      allow delete: if false;
    }

    match /tests/{testId} {
      allow read: if isAdmin();
      allow create: if isAdmin() &&
        request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin() &&
        keepsImmutableFields() &&
        resource.data.createdBy == request.auth.uid;
      allow delete: if isAdmin() && resource.data.createdBy == request.auth.uid;
    }

    match /questions/{questionId} {
      allow read: if isAdmin();
      allow create: if isAdmin() &&
        request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin() && keepsImmutableFields();
      allow delete: if isAdmin();
    }

    match /assignedTests/{assignedTestId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /learningSheets/{sheetId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin() && keepsImmutableFields() && resource.data.createdBy == request.auth.uid;
      allow delete: if isAdmin() && resource.data.createdBy == request.auth.uid;
    }

    match /practiceCourses/{courseId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() && keepsImmutableFields();
      allow delete: if isAdmin();
    }

    match /todos/{todoId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isAdmin());
      allow create: if isAuthenticated() && (isOwner(request.resource.data.studentId) || isAdmin());
      allow update: if isAuthenticated() && (
        (isOwner(resource.data.studentId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'dueDate', 'completed', 'completedAt'])) ||
        (isAdmin() && keepsImmutableFields())
      );
      allow delete: if isAuthenticated() && (isOwner(resource.data.studentId) || isAdmin());
    }

    match /customTopics/{topicId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    match /courses/{courseId} {
      allow read: if isAuthenticated() && (
        isAdmin() || request.auth.uid in resource.data.studentIds
      );
      allow create: if isAdmin() && request.resource.data.teacherId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /courseItems/{itemId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() && request.resource.data.addedBy == request.auth.uid;
    }
  }
}
